from flask import Flask, request, jsonify

app = Flask(__name__)

@app.route("/", methods=["POST"])
def main():
    return jsonify({
        "response": {
            "text": "сервер работает",
            "end_session": False
        },
        "version": "1.0"
    })

if __name__ == "__main__":
    app.run(port=5000)